{
  "private": true,
  "name": "benchmark",
  "type": "module",
  "version": "0.0.0",
  "description": "Benchmark for mobx-keystone",
  "main": "dist/index.js",
  "license": "MIT",
  "scripts": {
    "build": "shx rm -rf dist && tsc -p .",
    "bench-only": "cross-env NODE_ENV=production node dist/index.js",
    "bench": "pnpm run build && pnpm run bench-only",
    "bench:creation": "cross-env NODE_ENV=production node dist/creationBench.js",
    "bench:mutations": "cross-env NODE_ENV=production node dist/mutationBench.js",
    "bench:apply-snapshot": "cross-env NODE_ENV=production node dist/applySnapshotBench.js",
    "profile:empty-creation": "cross-env NODE_ENV=production node dist/profile.js empty-typechecked-model",
    "profile:creation:model": "cross-env NODE_ENV=production node dist/profile.js flat-model-creation",
    "profile:creation:datamodel": "cross-env NODE_ENV=production node dist/profile.js flat-datamodel-creation",
    "profile:apply-snapshot": "cross-env NODE_ENV=production node dist/profile.js apply-prop",
    "profile:mutations": "cross-env NODE_ENV=production node dist/profile.js reverse"
  },
  "peerDependencies": {
    "mobx": "^6.0.0"
  },
  "dependencies": {
    "benchmark": "^2.1.4",
    "chalk": "^5.6.2",
    "mobx-keystone": "workspace:*",
    "mobx-state-tree": "^7.3.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@types/benchmark": "^2.1.5",
    "@types/node": "^26.1.1",
    "cross-env": "^10.1.0",
    "shx": "^0.4.0",
    "typescript": "^7.0.2"
  }
}
