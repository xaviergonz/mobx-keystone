{
  // This file is not used in compilation. It is here just for a nice editor experience.
  // Mirrors @docusaurus/tsconfig, but inlined so we can drop its deprecated baseUrl for TS 6.
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "jsx": "preserve",
    "lib": ["ES2022", "DOM"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "target": "ES2022",
    "paths": {
      "@site/*": ["./*"]
    },
    "skipLibCheck": true,
    "strict": true
  },
  "include": ["*.ts", "src", "docs"]
}
