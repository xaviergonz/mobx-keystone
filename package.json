{
  "private": true,
  "name": "root",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "lib:build": "turbo run mobx-keystone#build",
    "lib:build-docs": "turbo run mobx-keystone#build-docs",
    "benchmark:build": "turbo run benchmark#build",
    "lib:test": "turbo run mobx-keystone#test",
    "lib:test:ci": "turbo run mobx-keystone#test:ci",
    "yjs-lib:build": "turbo run mobx-keystone-yjs#build",
    "yjs-lib:test": "turbo run mobx-keystone-yjs#test",
    "yjs-lib:test:ci": "turbo run mobx-keystone-yjs#test:ci",
    "loro-lib:build": "turbo run mobx-keystone-loro#build",
    "loro-lib:test": "turbo run mobx-keystone-loro#test",
    "loro-lib:test:ci": "turbo run mobx-keystone-loro#test:ci",
    "site:start": "turbo run site#start",
    "site:build": "turbo run site#build",
    "site:serve": "turbo run site#serve",
    "build-netlify": "pnpm run site:build",
    "netlify-dev": "pnpm run build-netlify && netlify dev",
    "lint": "biome check",
    "skills:sync": "npx -y skills add ./skills --skill '*' --agent codex claude-code github-copilot antigravity -y",
    "upgrade-interactive": "pnpm -r up -i --latest && pnpm dedupe"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "dependencies": {
    "loro-crdt": "^1.13.6",
    "mobx": "^6.16.1",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "globals": "^17.7.0",
    "netlify-cli": "^26.2.0",
    "turbo": "^2.10.4",
    "typescript": "^7.0.2"
  },
  "packageManager": "pnpm@11.10.0"
}
